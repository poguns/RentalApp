<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             xmlns:models="clr-namespace:StarterApp.Database.Models;assembly=StarterApp.Database"
             x:Class="StarterApp.Views.ItemsListPage"
             x:DataType="viewmodels:ItemsListViewModel"
             Title="Items">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add"
                     Command="{Binding GoToCreateItemCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsBusy}"
                 Command="{Binding LoadItemsCommand}">
        <ScrollView>
            <VerticalStackLayout>

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />

                <!-- Error message -->
                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="Red"
                       HorizontalOptions="Center"
                       Margin="16" />

                <VerticalStackLayout IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">

                    <!-- My Listings Header -->
                    <Grid Padding="16,12,16,4" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="My Listings"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding MyItems.Count, StringFormat='{0} items'}"
                               FontSize="13"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- My Items List -->
                    <CollectionView ItemsSource="{Binding MyItems}"
                                    HeightRequest="180">
                        <CollectionView.EmptyView>
                            <Label Text="You haven't listed any items yet"
                                   HorizontalOptions="Center"
                                   TextColor="Gray"
                                   Margin="16" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Item">
                                <Grid Padding="16,8" ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding Location}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemsListViewModel}}, Path=GoToItemDetailCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="16,8" />

                    <!-- All Items Header -->
                    <Label Text="All Items"
                           FontSize="18"
                           FontAttributes="Bold"
                           Margin="16,4,16,4" />

                    <!-- All Items List -->
                    <CollectionView ItemsSource="{Binding Items}">
                        <CollectionView.EmptyView>
                            <Label Text="No items found"
                                   HorizontalOptions="Center"
                                   TextColor="Gray"
                                   Margin="16" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Item">
                                <Grid Padding="16,8" ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding Location}"
                                               FontSize="12"
                                               TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding DailyRate, StringFormat='£{0:F2}/day'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ItemsListViewModel}}, Path=GoToItemDetailCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>